# ShopFlow v1.0.0 - Environment Variables
# Kopieer naar .env en vul in

# JWT Secret (verander dit in productie!)
JWT_SECRET=shopflow-change-this-secret-in-production

# Database (leeg = SQLite voor Replit, vul in voor Azure PostgreSQL)
DATABASE_URL=
SQLITE_PATH=shopflow.db

# AWS Bedrock (voor AI reparatiegidsen)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# Google OAuth (optioneel)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Server
PORT=8080
