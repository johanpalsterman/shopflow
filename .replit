run = "py main.py"
modules = ["python-3.11", "nodejs-20"]

[nix]
channel = "stable-23_11"
packages = ["cargo", "libiconv", "libxcrypt", "rustc"]

[deployment]
run = ["gunicorn", "--bind=0.0.0.0:5000", "--reuse-port", "--workers=2", "-k", "uvicorn.workers.UvicornWorker", "main:app"]
deploymentTarget = "autoscale"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 8080
externalPort = 80

[agent]
expertMode = true
integrations = ["github:1.0.0"]

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "PORT=5000 python main.py"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"
